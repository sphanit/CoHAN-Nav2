 <root BTCPP_format="4" >
	<BehaviorTree ID="MainTree">
		<ReactiveFallback>
			<!-- Condition -->
			<IsGoalUpdated name="goal_update_check" goal_update="{goal_update}" recovery="{recovery}"/>
			<ReactiveFallback name="goal_tree">
				<!-- First Control: Passage Detection -->
				<Sequence>
					<PassThrough name="is_passage_detected" passage_type="{passage_type}"/>
					<Timeout msec="5000">
						<SetMode plan_type="passthrough" predict_type="const_vel" mode="{planning_mode}"/>
					</Timeout>
				</Sequence>
				<!-- Second Control: Evasion Detection -->
				<ReactiveSequence>
					<Evade name="evasion_check" agents_info="{agents_info}" nearest_corner="{nearest_corner}" recovery="{recovery}" look_ahead_goal="{look_ahead_goal}"/>
					<SetMode name="evasion_mode" plan_type="evade" predict_type="const_vel" mode="{planning_mode}"/>
				</ReactiveSequence>
				<!-- Main Planning Mode Selection (Single/Dual/VelObs) -->
				<!-- SequenceWithMemory replaced with SequenceStar for BT v3 compatibility -->
				<SequenceStar>
					<ReactiveFallback>
						<SingleBandExitCond name="single band mode" agents_info="{agents_info}" dist_max="10"/>
						<SetMode plan_type="single" predict_type="const_vel" mode="{planning_mode}"/>
					</ReactiveFallback>
					<ReactiveFallback>
						<DualBandExitCond name="dual band mode" agents_info="{agents_info}" dist_threshold="2.5" nav_goal="{nav_goal}"/>
						<SetMode name="dual_band" plan_type="dual" predict_type="const_vel" mode="{planning_mode}"/>
					</ReactiveFallback>
					<ReactiveFallback>
						<VelObsExitCond name="velobs mode" agents_info="{agents_info}" agents_ptr="{agents_ptr}" stuck_agent="{stuck_agent}" valid_plan="{valid_plan}"/>
						<SetMode name="vel_obs" plan_type="velobs" predict_type="const_vel" mode="{planning_mode}"/>
					</ReactiveFallback>
				</SequenceStar>
			</ReactiveFallback>
		</ReactiveFallback>
	</BehaviorTree>
</root>
